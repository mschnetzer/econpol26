selfemployed = case_when(emplrel == 2 ~ 1, emplrel %in% c(1,3) ~ 0, TRUE ~ NA),
control = case_match(wkdcorga, 8:10 ~ 1, 5:7 ~ 2, 2:4 ~ 3, 0:1 ~4),
isco88 = isco08_to_isco88(isco08),
isco88com = isco88_to_isco88com(isco88),
wright = isco88com_to_wright(x = isco88com, is_supervisor = supervisor, self_employed = selfemployed, n_employees = emplno, control_work = iorgact, control_daily = control, type = "simple", label = T),
oesch5 = isco08_to_oesch(x = isco08, self_employed = selfemployed,
n_employees = emplno, n_classes = 5),
oesch8 = isco08_to_oesch(x = isco08, self_employed = selfemployed,
n_employees = emplno, n_classes = 8),
oesch16 = isco08_to_oesch(x = isco08, self_employed = selfemployed,
n_employees = emplno, n_classes = 16),
oesch6 = ifelse(oesch16 == 1, 0, as.numeric(oesch5)),
oesch = fct_reorder(case_match(oesch6,
0 ~ "Large employers",
1 ~ "Higher-grade service class",
2 ~ "Lower-grade service class",
3 ~ "Small business owners",
4 ~ "Skilled workers",
5 ~ "Unskilled workers"), oesch6))
